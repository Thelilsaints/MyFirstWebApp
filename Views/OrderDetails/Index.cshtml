@model IEnumerable<MyFirstWebApp.Models.OrderDetail>

@{
    ViewData["Title"] = "Order Details";
}

<div class="centered-frame">
    <h1 class="text-center">Order Details</h1>

    <p class="text-center mb-3">
        <a asp-action="Create" class="btn btn-warm">Create New</a>
    </p>

    <table class="table">
        <thead>
            <tr>
                <th>Order</th>
                <th>Product</th>
                <th>Quantity</th>
                <th>Unit Price</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var item in Model) {
            <tr>
                <td>@Html.DisplayFor(modelItem => item.Order.OrderId)</td>
                <td>@Html.DisplayFor(modelItem => item.Product.Name)</td>
                <td>@Html.DisplayFor(modelItem => item.Quantity)</td>
                <td>@Html.DisplayFor(modelItem => item.UnitPrice)</td>
                <td>
                    <div class="action-buttons">
                        <a asp-action="Edit" asp-route-id="@item.OrderDetailId" class="btn btn-warm btn-sm" role="button">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.OrderDetailId" class="btn btn-warm btn-sm" role="button">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.OrderDetailId" class="btn btn-warm-danger btn-sm" role="button">Delete</a>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
</div>