@{
    ViewData["Title"] = "Gestión de Productos";
}

<div class="centered-frame">
    <header class="management-header" role="banner" aria-labelledby="mg-title">
        <h1 id="mg-title" class="management-title">Gestión de Productos</h1>

        <nav class="management-buttons" role="navigation" aria-label="Navegación principal gestión">
            <a asp-controller="Products" asp-action="Index" class="btn btn-warm" role="button" aria-label="Ir a Productos">Productos</a>
            <a asp-controller="Categories" asp-action="Index" class="btn btn-warm" role="button" aria-label="Ir a Categorías">Categorías</a>
        </nav>

        <div class="welcome-box" role="region" aria-label="Bienvenida">
            <strong>Bienvenido al panel de gestión.</strong>
            <p>&nbsp;Explora nuestros productos y servicios: crea nuevos artículos, revisa detalles y organiza categorías para ofrecer la mejor experiencia a tus clientes.</p>
        </div>
    </header>
</div>
