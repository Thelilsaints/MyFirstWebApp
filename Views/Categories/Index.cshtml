@model IEnumerable<MyFirstWebApp.Models.Category>

@{
    ViewData["Title"] = "Categorías";
}

<div class="centered-frame">
    <h1 class="text-center">Categorías</h1>

    <p class="text-center mb-3">
        <a asp-action="Create" class="btn btn-warm">Create New</a>
    </p>

    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Name)
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    <div class="action-buttons">
                        <a asp-action="Edit" asp-route-id="@item.CategoryId" class="btn btn-warm btn-sm" role="button" aria-label="Edit category @item.CategoryId">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.CategoryId" class="btn btn-warm btn-sm" role="button" aria-label="Details category @item.CategoryId">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.CategoryId" class="btn btn-warm-danger btn-sm" role="button" aria-label="Delete category @item.CategoryId">Delete</a>
                    </div>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>
