@model IEnumerable<MyFirstWebApp.Models.Product>

@{
    ViewData["Title"] = "Productos";
}

<div class="centered-frame">
    <h1 class="text-center">Productos</h1>

    <p class="text-center mb-3">
        <a asp-action="Create" class="btn btn-warm">Create New</a>
    </p>

    <table class="table">
        <thead>
            <tr>
                <th>
                    @Html.DisplayNameFor(model => model.Name)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Price)
                </th>
                <th>
                    @Html.DisplayNameFor(model => model.Category)
                </th>
                <th></th>
            </tr>
        </thead>
        <tbody>
    @foreach (var item in Model) {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Price)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Category.CategoryId)
                </td>
                <td>
                    <div class="action-buttons">
                        <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-warm btn-sm" role="button" aria-label="Edit product @item.ProductId">Editar</a>
                        <a asp-action="Details" asp-route-id="@item.ProductId" class="btn btn-warm btn-sm" role="button" aria-label="Details product @item.ProductId">Detalles</a>
                        <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-warm-danger btn-sm" role="button" aria-label="Delete product @item.ProductId">Eliminar</a>
                    </div>
                </td>
            </tr>
    }
        </tbody>
    </table>
</div>
